{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@animora/typescript-config/base.json",
  "compilerOptions": {
    "lib": [
      "es2023"
    ],
    "target": "es2023",
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "noUncheckedIndexedAccess": false,
    "incremental": true
  },
  "include": [
    "src/**/*.ts"
  ]
}