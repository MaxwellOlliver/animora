{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["es2023"],
    "target": "es2023",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "noUncheckedIndexedAccess": false,
    "sourceMap": true,
    "removeComments": true
  }
}
