# ─────────────────────────────────────────────────────────────
# Image references (built locally, pushed to GHCR)
# ─────────────────────────────────────────────────────────────
API_IMAGE=ghcr.io/USERNAME/animora-api:latest
WEB_IMAGE=ghcr.io/USERNAME/animora-web:latest

# ─────────────────────────────────────────────────────────────
# Postgres
# ─────────────────────────────────────────────────────────────
POSTGRES_USER=animora
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=animora
DATABASE_URL=postgres://animora:CHANGE_ME@postgres:5432/animora

# ─────────────────────────────────────────────────────────────
# RabbitMQ (exposed on 127.0.0.1:5672 for Tailscale local worker)
# ─────────────────────────────────────────────────────────────
RABBITMQ_USER=animora
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_URL=amqp://animora:CHANGE_ME@rabbitmq:5672

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRATION=5m
JWT_REFRESH_EXPIRATION=7d

# ─────────────────────────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.animora.maxwellmacedo.com/api/auth/google/callback

# ─────────────────────────────────────────────────────────────
# URLs
# ─────────────────────────────────────────────────────────────
WEB_URL=https://animora.maxwellmacedo.com
APP_URL=https://animora.maxwellmacedo.com
API_URL=http://api:8080/api

# ─────────────────────────────────────────────────────────────
# Cloudflare R2
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=https://e96208ed116e8a5ceca849e0f31e58dd.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://pub-3d0c243e87664f8f87bda24a9e815cbd.r2.dev
S3_REGION=auto
S3_BUCKET=animora
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─────────────────────────────────────────────────────────────
# Web (server-side only — public ones are baked into the image)
# ─────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# ─────────────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────────────
SIGNUP_ENABLED=false

# ─────────────────────────────────────────────────────────────
# Seed (used once on first deploy via `bun run db:seed`)
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=maxwell@animora.com
SEED_ADMIN_PASSWORD=CHANGE_ME
SEED_ADMIN_NAME=Admin

# ─────────────────────────────────────────────────────────────
# Observability (optional)
# ─────────────────────────────────────────────────────────────
GRAFANA_LOKI_URL=
